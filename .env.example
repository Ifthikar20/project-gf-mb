# Better & Bliss - Environment Configuration
# Copy this file to .env and fill in real values
# NEVER commit .env with real secrets

# API
API_BASE_URL=https://api.betterandbliss.com
CDN_BASE_URL=https://cdn-dev.betterandbliss.app
API_KEY=your_api_key_here

# Feature flags
ENABLE_ANALYTICS=false
ENABLE_CRASH_REPORTING=false

# AWS Cognito (OAuth)
COGNITO_DOMAIN=https://your-app.auth.us-east-1.amazoncognito.com
COGNITO_CLIENT_ID=your_cognito_client_id
COGNITO_REGION=us-east-1

# CDN / Media
CLOUDFRONT_URL=https://your-distribution.cloudfront.net
R2_BASE_URL=https://your-bucket.r2.dev

# Analytics (GA4)
GA_MEASUREMENT_ID=G-XXXXXXXXXX
GA_API_SECRET=your_ga_api_secret
GA_ENABLED=false

# Certificate Pinning (optional)
API_CERT_HASH_1=
API_CERT_HASH_2=
